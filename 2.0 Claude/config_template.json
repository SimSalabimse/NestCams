# Configuration Template
# This file shows all available configuration options
# The actual config.json is auto-generated by the application

{
    # Motion Detection Settings
    "motion_sensitivity": 5,          # 1-10 (1=most sensitive, 10=least)
    "min_motion_duration": 0.5,       # Minimum seconds of motion to keep
    "motion_threshold": 25,           # Pixel difference threshold (1-100)
    "blur_size": 21,                  # Blur kernel size (odd number, 3-51)
    
    # Processing Settings
    "use_gpu": true,                  # Enable GPU acceleration if available
    "cpu_threads": 7,                 # Number of CPU threads (1-max cores)
    "output_quality": 2,              # 0=Low, 1=Medium, 2=High, 3=Maximum
    "smoothing": 5,                   # Speed smoothing level (0-10)
    
    # Default Directories (auto-populated)
    "last_input_dir": "",             # Last used input directory
    "last_output_dir": "",            # Last used output directory
    "last_music_dir": "",             # Last used music directory
    
    # Application Settings
    "check_updates_on_start": false,  # Check for updates when app starts
    "save_logs": true,                # Save processing logs
    "log_level": "INFO",              # DEBUG, INFO, WARNING, ERROR
    
    # Advanced Motion Detection (not in GUI)
    "min_motion_pixels": 1000,        # Minimum pixels for valid motion
    "motion_merge_gap": 2.0,          # Merge segments within N seconds
    "dilate_iterations": 2,           # Morphological dilation iterations
    
    # Advanced Processing (not in GUI)
    "temp_dir": "temp",               # Temporary files directory
    "keep_temp_files": false,         # Keep temporary files for debugging
    "segment_overlap": 0.1,           # Overlap between segments (seconds)
    
    # YouTube Settings (if configured)
    "youtube_default_privacy": "private",  # private, unlisted, public
    "youtube_default_category": "15",      # 15 = Pets & Animals
    
    # Video Output Settings
    "default_target_length": 60,      # Default target length in seconds
    "max_bitrate": "8M",             # Maximum output bitrate
    "audio_bitrate": "192k",         # Audio bitrate for music
    "pixel_format": "yuv420p",       # Pixel format for compatibility
    
    # Performance Tuning
    "buffer_size": 4096,             # Read buffer size (KB)
    "batch_size": 30,                # Frames to process in batch
    "memory_limit_mb": 4096          # Maximum memory usage (MB)
}

# Notes:
# - All time values are in seconds unless specified
# - Boolean values: true/false (lowercase)
# - File paths use forward slashes (/) even on Windows
# - This is a JSON file, remove all comments (#) for actual use
# - Settings not in GUI can be manually edited in config.json
